---
import BaseLayout from '../layouts/BaseLayout.astro';

// Add your opinions and tech articles here as you write them.
const articles: { title: string; date: string; summary: string; slug: string; tag?: string; tagClass?: string }[] = [
  // Example:
  // {
  //   title: 'Why I Think Service Mesh Is Overrated for Most Teams',
  //   date: 'Apr 2026',
  //   summary: 'A candid take on when service mesh adds value and when it just adds complexity.',
  //   slug: 'service-mesh-overrated',
  //   tag: 'Opinion',
  //   tagClass: 'tag-opinion',
  // },
];
---

<BaseLayout title="Articles">
  <div class="container">
    <div class="page-header">
      <h1>Opinions &amp; Tech Articles</h1>
      <p>My thoughts on cloud, containers, and the tech landscape</p>
    </div>

    {articles.length === 0 ? (
      <div class="empty-state">
        <div class="icon">✍️</div>
        <p>Articles coming soon. Stay tuned!</p>
      </div>
    ) : (
      <div class="card-list">
        {articles.map((article) => (
          <div class="content-card">
            <div class="meta">
              {article.tag && <span class={`tag ${article.tagClass}`}>{article.tag}</span>}
              <span class="date">{article.date}</span>
            </div>
            <h3>{article.title}</h3>
            <p class="summary">{article.summary}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
